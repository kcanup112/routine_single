# Environment Configuration for Multi-tenant SaaS
# Copy this file to .env and update with your actual values

# ===================================================================
# DATABASE CONFIGURATION
# ===================================================================
DB_PASSWORD=your_secure_postgres_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kec_routine_saas
DB_USER=kec_admin

# ===================================================================
# REDIS CONFIGURATION
# ===================================================================
REDIS_PASSWORD=your_redis_password_here
REDIS_HOST=localhost
REDIS_PORT=6379

# ===================================================================
# APPLICATION SECRETS
# ===================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30

# ===================================================================
# ENVIRONMENT
# ===================================================================
ENVIRONMENT=development  # development, staging, production
DEBUG=true
LOG_LEVEL=INFO

# ===================================================================
# CORS & SECURITY
# ===================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourapp.com
ALLOWED_HOSTS=localhost,127.0.0.1,*.yourapp.com
CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://yourapp.com

# ===================================================================
# FILE UPLOAD
# ===================================================================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.pdf,.csv,.xlsx

# ===================================================================
# EMAIL CONFIGURATION (for invitations & notifications)
# ===================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_TLS=true
FROM_EMAIL=noreply@yourapp.com
FROM_NAME=KEC Routine Scheduler

# ===================================================================
# PAYMENT GATEWAYS
# ===================================================================
# Stripe
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Khalti (Nepal)
KHALTI_PUBLIC_KEY=your_khalti_public_key
KHALTI_SECRET_KEY=your_khalti_secret_key

# eSewa (Nepal)
ESEWA_MERCHANT_ID=your_esewa_merchant_id
ESEWA_SECRET_KEY=your_esewa_secret_key

# ===================================================================
# STORAGE (AWS S3 / Compatible)
# ===================================================================
STORAGE_BACKEND=local  # local, s3, minio
S3_BUCKET_NAME=kec-routine-uploads
S3_REGION=ap-south-1
S3_ACCESS_KEY=your_aws_access_key
S3_SECRET_KEY=your_aws_secret_key
S3_ENDPOINT_URL=  # Leave empty for AWS, set for MinIO/DigitalOcean Spaces

# ===================================================================
# PGADMIN
# ===================================================================
PGADMIN_EMAIL=admin@kec.edu.np
PGADMIN_PASSWORD=admin

# ===================================================================
# APPLICATION SETTINGS
# ===================================================================
APP_NAME=KEC Routine Scheduler
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
SUPPORT_EMAIL=support@yourapp.com

# Trial Configuration
TRIAL_DAYS=14
GRACE_PERIOD_DAYS=7

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ===================================================================
# MONITORING (Optional)
# ===================================================================
SENTRY_DSN=  # Sentry error tracking
GOOGLE_ANALYTICS_ID=  # GA tracking ID

# ===================================================================
# TENANT DEFAULTS
# ===================================================================
DEFAULT_TIMEZONE=Asia/Kathmandu
DEFAULT_LOCALE=en-US
DEFAULT_CALENDAR_TYPE=ad  # ad or bs
DEFAULT_WORKING_DAYS=0,1,2,3,4,5  # Sunday to Friday
DEFAULT_WEEKEND_DAYS=5,6  # Friday, Saturday
